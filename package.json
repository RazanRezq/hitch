{
  "name": "hitch",
  "version": "0.0.0",
  "private": true,
  "description": "Ride-booking platform for KEF ↔ Reykjavík airport transfers",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next dist node_modules/.prisma",
    "ws": "node --env-file=.env --import tsx src/server/index.ts",
    "ws:dev": "node --env-file=.env --import tsx --watch src/server/index.ts",
    "workers": "node --env-file=.env --import tsx src/server/workers/index.ts",
    "workers:dev": "node --env-file=.env --import tsx --watch src/server/workers/index.ts",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md,css}\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.709.0",
    "@aws-sdk/s3-request-presigner": "^3.709.0",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.6",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.1.0",
    "@radix-ui/react-direction": "^1.1.0",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "^9.6.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "better-auth": "^1.1.0",
    "bullmq": "^5.34.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.6.14",
    "ioredis": "^5.4.1",
    "libphonenumber-js": "^1.13.3",
    "lucide-react": "^0.468.0",
    "next": "16.2.4",
    "next-intl": "^4.9.0",
    "partysocket": "^1.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.0",
    "stripe": "^17.5.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.10.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
