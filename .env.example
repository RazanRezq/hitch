# =============================================================================
# Hitch — Environment Variables
# Copy to .env (never commit .env) and fill in real values.
# =============================================================================

# -- Database ----------------------------------------------------------------
# Railway Managed PostgreSQL. For local dev with SQLite:
#   DATABASE_URL="file:./dev.db"
DATABASE_URL="postgresql://user:password@localhost:5432/hitch?schema=public"

# -- Redis (BullMQ + pub/sub) ------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -- Better Auth -------------------------------------------------------------
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3001"

# -- Stripe (multi-currency, manual capture) ---------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# -- DigitalOcean Spaces (S3-compatible, Frankfurt region) -------------------
DO_SPACES_ENDPOINT="https://fra1.digitaloceanspaces.com"
DO_SPACES_REGION="fra1"
DO_SPACES_BUCKET="hitch-dev"
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
DO_SPACES_CDN_URL="https://hitch-dev.fra1.cdn.digitaloceanspaces.com"

# -- Google Maps -------------------------------------------------------------
# Frontend key (restrict by referrer in Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""
# Backend key for Directions/Geocoding (restrict by IP)
GOOGLE_MAPS_SERVER_KEY=""

# -- WebSocket ---------------------------------------------------------------
# In prod: wss://api.hitch.is/ws
NEXT_PUBLIC_WS_URL="ws://localhost:3001/ws"

# -- Exchange Rate API -------------------------------------------------------
# e.g. exchangerate.host
EXCHANGE_RATE_API_KEY=""

# -- Seed (dev only) ---------------------------------------------------------
SEED_ADMIN_EMAIL="admin@hitch.is"
SEED_ADMIN_PASSWORD="change-me-in-dev"

# -- App URLs (for CORS + redirects) -----------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_PASSENGER_URL="http://localhost:3000"
NEXT_PUBLIC_DASHBOARD_URL="http://localhost:3002"
