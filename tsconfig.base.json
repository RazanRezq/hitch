{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowJs": false,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@hitch/db": ["packages/db/src/index.ts"],
      "@hitch/db/*": ["packages/db/src/*"],
      "@hitch/types": ["packages/types/src/index.ts"],
      "@hitch/types/*": ["packages/types/src/*"],
      "@hitch/i18n": ["packages/i18n/src/index.ts"],
      "@hitch/i18n/*": ["packages/i18n/src/*"],
      "@hitch/utils": ["packages/utils/src/index.ts"],
      "@hitch/utils/*": ["packages/utils/src/*"],
      "@hitch/auth": ["packages/auth/src/index.ts"],
      "@hitch/auth/*": ["packages/auth/src/*"],
      "@hitch/ui": ["packages/ui/src/index.ts"],
      "@hitch/ui/*": ["packages/ui/src/*"],
      "@hitch/api-client": ["packages/api-client/src/index.ts"],
      "@hitch/api-client/*": ["packages/api-client/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".turbo"]
}
