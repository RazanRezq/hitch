// =============================================================================
// Hitch — Prisma schema
// Source of truth for the data model. See HITCH_MASTER_PLAN.md §8.
// Money is ALWAYS stored in ISK; display currency is derived.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -- Enums ------------------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  DISPATCHER
  DRIVER
  PASSENGER
}

enum Locale {
  is
  en
  ar
}

enum Currency {
  ISK
  EUR
  USD
}

enum VehicleType {
  SEDAN
  SUV
  VAN
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  SEARCHING
  ACCEPTED
  DRIVER_ARRIVING
  DRIVER_ARRIVED
  IN_TRANSIT
  COMPLETED
  CANCELLED_BY_PASSENGER
  CANCELLED_BY_DRIVER
  CANCELLED_BY_SYSTEM
  NO_SHOW
  DISPUTED
}

enum PaymentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  REQUIRES_CAPTURE
  PROCESSING
  SUCCEEDED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
}

enum PayoutStatus {
  PENDING
  IN_TRANSIT
  PAID
  FAILED
}

enum DocumentType {
  LICENSE
  INSURANCE
  REGISTRATION
  BACKGROUND_CHECK
}

enum DiscountType {
  PERCENT
  FIXED
}

enum BookingEventType {
  CREATED
  STATUS_CHANGED
  DRIVER_ASSIGNED
  DRIVER_UNASSIGNED
  PAYMENT_AUTHORIZED
  PAYMENT_CAPTURED
  PAYMENT_REFUNDED
  DISPATCH_OFFERED
  DISPATCH_ACCEPTED
  DISPATCH_REJECTED
  NOTE_ADDED
}

// -- Core Domain ------------------------------------------------------------

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  phone                   String?   @unique
  name                    String?
  avatarUrl               String?
  role                    UserRole  @default(PASSENGER)
  stripeCustomerId        String?   @unique
  stripeConnectAccountId  String?   @unique
  phoneVerifiedAt         DateTime?
  emailVerifiedAt         DateTime?
  preferredLocale         Locale    @default(is)
  preferredCurrency       Currency  @default(ISK)
  isGuest                 Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relations
  sessions         Session[]
  accounts         Account[]
  verifications    Verification[]
  vehiclesAsDriver Vehicle[]         @relation("VehicleDriver")
  bookingsAsPassenger Booking[]      @relation("BookingPassenger")
  bookingsAsDriver    Booking[]      @relation("BookingDriver")
  driverLocation   DriverLocation?
  driverDocuments  DriverDocument[]
  ratingsGiven     Rating[]          @relation("RatingRater")
  ratingsReceived  Rating[]          @relation("RatingRatee")
  driverPayouts    DriverPayout[]
  promoRedemptions PromoRedemption[]
  bookingEvents    BookingEvent[]

  @@index([role])
  @@index([stripeCustomerId])
}

model Vehicle {
  id           String      @id @default(cuid())
  driverId     String
  vehicleType  VehicleType
  capacity     Int
  licensePlate String      @unique
  make         String
  model        String
  year         Int
  color        String
  photos       String[]
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  driver   User      @relation("VehicleDriver", fields: [driverId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([driverId])
  @@index([vehicleType, isActive])
}

model Booking {
  id           String @id @default(cuid())
  passengerId  String
  driverId     String?
  vehicleId    String?

  // Locations
  pickupLat         Float
  pickupLng         Float
  pickupAddress     String
  dropoffLat        Float
  dropoffLng        Float
  dropoffAddress    String
  pickupAirportCode String?
  flightNumber      String?

  // Timing
  scheduledTime     DateTime
  estimatedPickupAt DateTime?
  actualPickupAt    DateTime?
  actualDropoffAt   DateTime?

  // Distance
  estimatedDistanceKm Float?
  actualDistanceKm    Float?

  // Trip details
  vehicleTypeRequested VehicleType
  passengerCount       Int         @default(1)

  // Pricing — ISK is source of truth
  basePriceISK     Int
  displayCurrency  Currency @default(ISK)
  displayPrice     Int      // amount in displayCurrency smallest unit (ISK has no decimals)
  exchangeRate     Float    @default(1.0) // locked at booking time

  // Cancellation
  cancellationReason String?
  cancellationFee    Int?

  status    BookingStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  passenger        User                  @relation("BookingPassenger", fields: [passengerId], references: [id])
  driver           User?                 @relation("BookingDriver", fields: [driverId], references: [id])
  vehicle          Vehicle?              @relation(fields: [vehicleId], references: [id])
  events           BookingEvent[]
  payments         Payment[]
  locationHistory  TripLocationHistory[]
  ratings          Rating[]
  promoRedemptions PromoRedemption[]

  @@index([driverId, status])
  @@index([passengerId, createdAt])
  @@index([status, scheduledTime])
  @@index([status])
}

model BookingEvent {
  id        String           @id @default(cuid())
  bookingId String
  type      BookingEventType
  payload   Json?
  actorId   String?
  createdAt DateTime         @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id])

  @@index([bookingId, createdAt])
  @@index([type, createdAt])
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  stripeIntentId  String        @unique
  amount          Int           // in display currency smallest unit
  currency        Currency
  amountISK       Int           // always stored for accounting
  status          PaymentStatus
  capturedAt      DateTime?
  refundedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
}

model DriverPayout {
  id                  String       @id @default(cuid())
  driverId            String
  periodStart         DateTime
  periodEnd           DateTime
  grossAmountISK      Int
  commissionAmountISK Int
  netAmountISK        Int
  stripeTransferId    String?
  status              PayoutStatus @default(PENDING)
  bookingIds          String[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  driver User @relation(fields: [driverId], references: [id])

  @@index([driverId, periodStart])
  @@index([status])
}

model DriverLocation {
  driverId  String   @id
  lat       Float
  lng       Float
  heading   Float?
  isOnline  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  driver User @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([isOnline])
}

model TripLocationHistory {
  id        String   @id @default(cuid())
  bookingId String
  lat       Float
  lng       Float
  timestamp DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, timestamp])
}

model DriverDocument {
  id           String       @id @default(cuid())
  driverId     String
  type         DocumentType
  fileUrl      String
  expiresAt    DateTime?
  verifiedAt   DateTime?
  verifiedById String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  driver User @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, type])
}

model Rating {
  id        String   @id @default(cuid())
  bookingId String
  raterId   String
  rateeId   String
  score     Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  rater   User    @relation("RatingRater", fields: [raterId], references: [id])
  ratee   User    @relation("RatingRatee", fields: [rateeId], references: [id])

  @@unique([bookingId, raterId])
  @@index([rateeId])
}

model PricingZone {
  id                   String   @id @default(cuid())
  name                 Json     // { is: "...", en: "...", ar: "..." }
  polygon              Json     // GeoJSON polygon
  baseFareISK          Int
  perKmRateISK         Int
  airportSurchargeISK  Int      @default(0)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([isActive])
}

model PromoCode {
  id              String       @id @default(cuid())
  code            String       @unique
  discountType    DiscountType
  discountValueISK Int         // for PERCENT this is basis-points (1000 = 10%); for FIXED this is ISK amount
  maxUses         Int?
  usesCount       Int          @default(0)
  validFrom       DateTime
  validUntil      DateTime?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  redemptions PromoRedemption[]

  @@index([code, isActive])
}

model PromoRedemption {
  id                  String   @id @default(cuid())
  promoCodeId         String
  bookingId           String
  userId              String
  discountAppliedISK  Int
  createdAt           DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  booking   Booking   @relation(fields: [bookingId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([bookingId, promoCodeId])
  @@index([promoCodeId])
  @@index([userId])
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency Currency // always ISK for now
  toCurrency   Currency
  rate         Float
  fetchedAt    DateTime @default(now())

  @@index([toCurrency, fetchedAt])
}

// -- Webhook Outbox (Stripe) ------------------------------------------------

model WebhookEvent {
  id          String    @id @default(cuid())
  source      String    // "stripe"
  externalId  String    @unique // Stripe event.id — idempotency
  type        String
  payload     Json
  status      String    @default("pending") // pending | processed | failed
  attempts    Int       @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, createdAt])
}

// -- Better Auth ------------------------------------------------------------

model Session {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identifier])
}
